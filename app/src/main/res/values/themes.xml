<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.NammaVastra" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primary_maroon</item>
        <item name="colorPrimaryVariant">@color/primary_maroon_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_gold</item>
        <item name="colorSecondaryVariant">@color/accent_gold</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/primary_maroon_dark</item>
    </style>

    <style name="Theme.NammaVastra.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.NammaVastra.Splash" parent="Theme.NammaVastra.NoActionBar">
        <item name="android:windowBackground">@color/splash_bg</item>
    </style>

    <style name="Theme.NammaVastra.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.NammaVastra.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

</resources>
